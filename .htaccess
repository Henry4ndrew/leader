RewriteEngine On

# Evitar problemas si no existe archivo o carpeta
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# URLs amigables para pĂ¡ginas
RewriteRule ^mi-empresa$ mi_empresa.php [L]
RewriteRule ^oportunidad$ oportunidad.php [L]
RewriteRule ^plan-marketing$ plan_marketing.php [L]
RewriteRule ^salud$ salud.php [L]
RewriteRule ^sobre-mi$ sobre_mi.php [L]

# PĂ¡gina dinĂ¡mica por serie
RewriteRule ^productos/(.+)$ productos.php?serie=$1 [L]